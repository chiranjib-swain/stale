{
  "name": "stale-action",
  "version": "10.0.0",
  "private": true,
  "description": "Marks old issues and PRs as stale",
  "type": "module",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.app.json && ncc build lib/main.js -o dist",
    "format": "prettier --no-error-on-unmatched-pattern --config  ./.prettierrc.cjs --write \"**/*.{ts,yml,yaml}\"",
    "format-check": "prettier --no-error-on-unmatched-pattern --config ./.prettierrc.cjs --check \"**/*.{ts,yml,yaml}\"",
    "lint": "eslint \"**/*.ts\"",
    "lint:fix": "eslint \"**/*.ts\" --fix",
    "lint:all": "npm run format-check && npm run lint",
    "lint:all:fix": "npm run format && npm run lint:fix",
    "test": "jest --config ./jest.config.cjs",
    "test:only-errors": "jest --reporters jest-silent-reporter --silent",
    "test:watch": "jest --watch --notify --expand",
    "all": "npm run format && npm run lint && npm run build && npm test",
    "all:ci": "npm run format && npm run lint && npm run build && npm run test:only-errors",
    "prerelease": "npm run build",
    "release": "standard-version",
    "release:dry-run": "standard-version --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actions/stale.git"
  },
  "keywords": [
    "actions",
    "node",
    "stale"
  ],
  "engines": {
    "node": "24",
    "npm": ">=7.0.0"
  },
  "author": "GitHub",
  "license": "MIT",
  "dependencies": {
    "@actions/cache": "^5.0.2",
    "@actions/core": "^1.11.1",
    "@actions/github": "^8.0.1",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-retry": "^8.1.0",
    "lodash.deburr": "^4.1.0",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/lodash.deburr": "^4.1.6",
    "@types/node": "^24.3.1",
    "@types/semver": "^7.5.0",
    "@vercel/ncc": "^0.36.1",
    "ansi-styles": "5.2.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-n": "^17.24.0",
    "jest": "^29.6.2",
    "jest-circus": "^29.5.0",
    "jest-silent-reporter": "^0.5.0",
    "js-yaml": "^4.1.1",
    "prettier": "^2.8.7",
    "standard-version": "^9.3.1",
    "terminal-link": "^2.1.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.57.1"
  },
  "overrides": {
    "@actions/http-client": "^3.0.2"
  }
}
